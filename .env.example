# ─── Database ─────────────────────────────────────────────────────────────
# Runtime connection (pooler, port 6543) — used by the app
DATABASE_URL=
# Migration connection (direct, port 5432) — used by drizzle-kit only
DATABASE_URL_DIRECT=

# ─── BetterAuth ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Full public URL of your app (e.g. http://localhost:3000 in dev)
BETTER_AUTH_URL=

# ─── OAuth — Google ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth — GitHub ───────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── OAuth — LinkedIn ─────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Admin ────────────────────────────────────────────────────────────────
# Comma-separated list of emails allowed to sign in as admin
# e.g. ADMIN_EMAIL=you@gmail.com,you@github.com
ADMIN_EMAIL=

# ─── Supabase ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for server-side storage operations (file upload, signed URLs)
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ──────────────────────────────────────────────────────────────────
# Full public URL of your app — same value as BETTER_AUTH_URL
NEXT_PUBLIC_APP_URL=

# ─── Groq (required for "Ask JV" AI chat widget) ──────────────────────────
GROQ_API_KEY=gsk_...

# ─── Resend (optional — required for contact form) ────────────────────────
RESEND_API_KEY=
RESEND_FROM_DOMAIN=
